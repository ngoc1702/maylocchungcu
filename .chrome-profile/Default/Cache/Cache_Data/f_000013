                if (host === 'youtu.be') {
                    videoId = parsedUrl.pathname.split('/').filter(Boolean)[0];
                    return videoId ? { type: 'iframe', url: 'https://www.youtube.com/embed/' + videoId + '?autoplay=1&rel=0' } : null;
